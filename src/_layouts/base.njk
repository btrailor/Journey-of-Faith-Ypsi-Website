  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  {% if customJs %}
  <script src="{{ customJs }}"></script>
  {% endif %}

  <!-- Launcher Toggle Script -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const launcher = document.getElementById('launcher');
      const launcherToggle = launcher.querySelector('.launcher-toggle');
      
      launcherToggle.addEventListener('click', () => {
        launcher.classList.toggle('active');
      });
      
      // Close launcher when clicking outside
      document.addEventListener('click', (e) => {
        if (!launcher.contains(e.target)) {
          launcher.classList.remove('active');
        }
      });
    });
  </script>

  <!-- Netlify Identity Widget -->
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>

  <!-- Safari Video Debug Script -->
  <script src="/js/safari-video-debug.js"></script>
</body>
</html>
